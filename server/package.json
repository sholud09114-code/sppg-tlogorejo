{
  "name": "sppg-server",
  "version": "1.0.0",
  "description": "SPPG Tlogorejo — Express API",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "node --check src/app.js",
    "lint": "eslint src eslint.config.js",
    "format": "prettier --write \"src/**/*.js\" \"*.{js,json}\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.8.3"
  }
}
