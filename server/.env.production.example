# Copy values to your hosting provider environment settings.
NODE_ENV=production
PORT=4000
CLIENT_URL=https://frontend-domain.example

DB_HOST=mysql-host.example
DB_PORT=3306
DB_USER=sppg_app
DB_PASSWORD=change-this-strong-password
DB_NAME=sppg_tlogorejo
DB_SSL=true
# Optional. Paste CA certificate content with \n line breaks if your provider requires it.
DB_SSL_CA=
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-chars
JWT_EXPIRES_IN=8h

# Required only for image import features.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Used only when the users table is still empty.
DEFAULT_ADMIN_NAME=Admin SPPG
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_PUBLIC_NAME=Publik
DEFAULT_PUBLIC_USERNAME=publik
DEFAULT_PUBLIC_PASSWORD=change-this-public-password
