# Copy this file to .env and adjust values
PORT=4000
# Comma-separated list. Tambahkan domain produksi + IP fallback.
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sppg_tlogorejo

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Google Drive (Report Editor photos + Dokumentasi module).
# Buat OAuth Web Client di https://console.cloud.google.com/apis/credentials
# Tambahkan redirect URI berikut: http://localhost:4000/api/gdrive/oauth/callback
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REDIRECT_URI=http://localhost:4000/api/gdrive/oauth/callback

JWT_SECRET=replace-with-a-long-random-secret-generated-for-this-environment
JWT_EXPIRES_IN=8h

# Digunakan hanya saat tabel users masih kosong.
DEFAULT_ADMIN_NAME=Admin SPPG
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_PUBLIC_NAME=Publik
DEFAULT_PUBLIC_USERNAME=publik
DEFAULT_PUBLIC_PASSWORD=publik12345
